# Virtual environment - never commit
venv/
env/
.env/

# Environment variables and secrets - NEVER commit
.env
*.env

# Data files - too large, regenerated by pipeline
data/raw/*
data/processed/*
data/validation_reports/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/validation_reports/.gitkeep

# Model weights - too large for git
models/*
!models/.gitkeep

